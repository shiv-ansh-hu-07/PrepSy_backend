datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String   @unique
  password    String?          
  provider    String   @default("local")
  providerId  String?
  loginStreak Int      @default(0)
  lastLoginAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roomsOwned  Room[]       @relation("UserOwnedRooms")
  roomMembers RoomMember[]
  attendance  RoomAttendance[]

  @@unique([provider, providerId])
}


model Room {
  id     String @id @default(cuid())
  roomId String @unique
  name   String
  description String?     
  tags        String[]

  ownerId   String?
  owner     User?        @relation("UserOwnedRooms", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())

  visibility  RoomVisibility @default(PRIVATE)

  startTime          DateTime?
  durationMinutes    Int?
  isRecurring        Boolean   @default(false)
  recurrenceType     String?   
  recurrenceEndDate  DateTime?

  remindersent Boolean @default(false)

  members  RoomMember[]
  messages Message[]
  pomodoro Pomodoro?
  attendance RoomAttendance[]

  @@index([ownerId, createdAt])
}

enum RoomVisibility {
  PUBLIC
  PRIVATE
}

model RoomMember {
  id       String   @id @default(cuid())
  roomId   String
  userId   String
  joinedAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [roomId])
  user User @relation(fields: [userId], references: [id])

  @@index([userId, roomId])
}

model Message {
  id         String   @id @default(cuid())
  roomId     String
  senderId   String?
  senderName String?
  text       String
  createdAt  DateTime @default(now())

  room Room @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@index([roomId])
}

model Pomodoro {
  id        String   @id @default(cuid())
  roomId    String   @unique
  running   Boolean  @default(false)
  mode      String   @default("work")
  remaining Int      @default(1500)
  updatedAt DateTime @updatedAt

  room Room @relation(fields: [roomId], references: [roomId])
}

model RoomAttendance {
  id        String   @id @default(cuid())
  roomId    String
  userId    String
  joinedAt  DateTime @default(now())
  leftAt    DateTime?

  room Room @relation(fields: [roomId], references: [roomId])
  user User @relation(fields: [userId], references: [id])

  @@index([roomId])
}
